@import "../../styles/variables.wxss";

.header {
  padding: 32rpx 32rpx 16rpx;
}

.date-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.greeting {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-top: 8rpx;
}

.cycle-info {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.beauty-time-card {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #fff;
  padding: 40rpx 32rpx;
}

.beauty-time-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.beauty-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.beauty-value-wrap {
  margin-top: 8rpx;
}

.beauty-value {
  font-size: 72rpx;
  font-weight: 700;
}

.beauty-unit {
  font-size: 28rpx;
  margin-left: 8rpx;
}

.beauty-desc {
  display: block;
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 8rpx;
}

.beauty-icon {
  font-size: 80rpx;
  opacity: 0.9;
}

.relief-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx solid var(--color-primary);
}

.relief-text {
  flex: 1;
}

.relief-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.relief-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
}

.relief-btn {
  background: var(--color-primary);
  color: #fff;
  border-radius: 44rpx;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1;
  border: none;
}

.relief-btn::after { border: none; }

.tips-card .tip-item {
  display: flex;
  align-items: flex-start;
  margin-top: 16rpx;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  margin-top: 2rpx;
}

.tip-content {
  flex: 1;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 500;
}

.tip-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.link-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.recent-list {
  margin-top: 16rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.recent-item:last-child {
  border-bottom: none;
}

.intensity-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.intensity-low { background: var(--color-success); }
.intensity-mid { background: var(--color-warning); }
.intensity-high { background: var(--color-danger); }

.recent-info {
  flex: 1;
}

.recent-title {
  font-size: 28rpx;
  font-weight: 500;
}

.recent-sub {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-left: 8rpx;
}

.recent-date {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.arrow {
  font-size: 32rpx;
  color: #ddd;
}

.empty-recent {
  text-align: center;
  padding: 40rpx 0;
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.alert-card {
  display: flex;
  align-items: flex-start;
  border-left: 6rpx solid var(--color-warning);
}

.alert-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.alert-content {
  flex: 1;
}

.alert-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-warning);
}

.alert-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  line-height: 1.5;
}

.alert-btn {
  display: inline-block;
  margin-top: 16rpx;
  background: var(--color-warning);
  color: #fff;
  border-radius: 28rpx;
  padding: 10rpx 24rpx;
  font-size: 22rpx;
  line-height: 1;
  border: none;
}

.alert-btn::after { border: none; }
