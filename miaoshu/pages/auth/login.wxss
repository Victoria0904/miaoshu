@import "../../styles/variables.wxss";

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 48rpx;
  box-sizing: border-box;
}

.login-box {
  width: 100%;
  max-width: 560rpx;
  text-align: center;
}

.logo {
  font-size: 120rpx;
  display: block;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-primary);
  display: block;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 80rpx;
}

.privacy-box {
  display: flex;
  align-items: flex-start;
  text-align: left;
  margin-bottom: 40rpx;
}

.privacy-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  margin-left: 12rpx;
}

.link {
  color: var(--color-primary);
}

.btn-disabled {
  opacity: 0.5;
}

.disclaimer {
  position: absolute;
  bottom: 40rpx;
  left: 48rpx;
  right: 48rpx;
  text-align: center;
}
