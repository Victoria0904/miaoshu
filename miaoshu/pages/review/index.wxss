@import "../../styles/variables.wxss";

.header {
  padding: 32rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.beauty-card {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #fff;
  text-align: center;
  padding: 48rpx 32rpx;
}

.beauty-label {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
}

.beauty-value-wrap {
  margin-top: 16rpx;
}

.beauty-value {
  font-size: 96rpx;
  font-weight: 700;
}

.beauty-unit {
  font-size: 32rpx;
  margin-left: 8rpx;
}

.beauty-desc {
  display: block;
  font-size: 24rpx;
  opacity: 0.85;
  margin-top: 8rpx;
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.highlight {
  color: var(--color-primary);
  font-weight: 600;
}

.chart {
  width: 100%;
  height: 480rpx;
}

.breakdown-list {
  margin-top: 16rpx;
}

.breakdown-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.breakdown-item:last-child {
  border-bottom: none;
}

.breakdown-left {
  display: flex;
  align-items: center;
}

.breakdown-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
}

.breakdown-name {
  font-size: 28rpx;
}

.breakdown-right {
  display: flex;
  align-items: center;
}

.breakdown-hours {
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 8rpx;
}

.breakdown-percent {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.trend-summary {
  margin-top: 16rpx;
}

.trend-text {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  padding: 4rpx 0;
}

.trend-num {
  color: var(--color-text);
  font-weight: 600;
}

.trend-alert {
  display: block;
  font-size: 24rpx;
  color: var(--color-warning);
  margin-top: 8rpx;
}

.suggestion-card {
  border-left: 6rpx solid var(--color-primary);
}

.suggestion-list {
  margin-top: 16rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.suggestion-dot {
  color: var(--color-primary);
  margin-right: 12rpx;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.suggestion-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text);
  line-height: 1.6;
}

.suggestion-notice {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-top: 16rpx;
}

.logic-list {
  margin-top: 12rpx;
}

.logic-item {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  padding: 8rpx 0;
}
