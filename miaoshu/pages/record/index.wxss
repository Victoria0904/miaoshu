@import "../../styles/variables.wxss";

.header {
  padding: 32rpx 32rpx 16rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.card-title-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.link-text {
  font-size: 24rpx;
  color: var(--color-primary);
}

.body-map-container {
  position: relative;
  width: 100%;
  height: 600rpx;
  margin: 0 auto;
}

.body-map-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.body-map-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.dot-list {
  margin-top: 20rpx;
}

.dot-item {
  display: flex;
  align-items: center;
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.dot-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.dot-label {
  flex: 1;
  font-size: 26rpx;
}

.dot-picker {
  margin-right: 16rpx;
}

.dot-intensity {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.dot-remove {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx;
}

.empty-tip {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  margin-top: 16rpx;
}

.slider-wrap {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
}

.slider-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.pain-slider {
  flex: 1;
  margin: 0 20rpx;
}

.intensity-display {
  text-align: center;
  margin-top: 16rpx;
}

.intensity-number {
  font-size: 72rpx;
  font-weight: 700;
}

.intensity-total {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.intensity-desc {
  display: block;
  text-align: center;
  font-size: 26rpx;
  margin-top: 8rpx;
}

.intensity-low { color: var(--color-success); }
.intensity-mid { color: var(--color-warning); }
.intensity-high { color: var(--color-danger); }

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.save-wrap {
  margin: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.view-switch {
  display: flex;
  background: #f5f5f5;
  border-radius: 28rpx;
  padding: 4rpx;
}

.view-option {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  color: var(--color-text-secondary);
}

.view-active {
  background: #fff;
  color: var(--color-primary);
  font-weight: 600;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
}

.record-list {
  margin-top: 16rpx;
}

.record-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-title {
  font-size: 28rpx;
  font-weight: 500;
}

.record-sub {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.record-date {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.symptom-wrap {
  margin-top: 8rpx;
}

.mini-tag {
  display: inline-block;
  font-size: 20rpx;
  color: var(--color-primary);
  background: var(--color-primary-light);
  border-radius: 8rpx;
  padding: 2rpx 10rpx;
  margin-right: 8rpx;
  margin-bottom: 6rpx;
}

.scene-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 日历 */
.calendar-view {
  margin-top: 16rpx;
}

.cal-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.cal-arrow {
  font-size: 36rpx;
  color: var(--color-text-secondary);
  padding: 8rpx 16rpx;
}

.cal-title {
  font-size: 28rpx;
  font-weight: 600;
}

.week-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 8rpx;
}

.week-day {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.cal-cell {
  aspect-ratio: 1;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f9f9f9;
  position: relative;
}

.cal-cell.empty {
  background: transparent;
}

.cal-cell.period {
  background: var(--color-primary-light);
}

.cal-day {
  font-size: 24rpx;
  color: var(--color-text);
}

.today-text {
  color: var(--color-primary);
  font-weight: 700;
}

.period-day {
  font-size: 18rpx;
  color: var(--color-primary);
}

.pain-bar {
  width: 28rpx;
  height: 8rpx;
  border-radius: 4rpx;
  margin-top: 4rpx;
}

.pain-low { background: var(--color-success); }
.pain-mid { background: var(--color-warning); }
.pain-high { background: var(--color-danger); }

.non-period-dot {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #C5A3FF;
}
