@import "../../styles/variables.wxss";

.header {
  padding: 32rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
}

.user-card {
  display: flex;
  align-items: center;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
}

.nickname {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.user-meta {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.card-title-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.tag-notice {
  font-size: 20rpx;
  color: var(--color-warning);
  background: #fff5e6;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
}

.report-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
}

.generating-box {
  text-align: center;
  padding: 48rpx 0;
}

.robot {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.generating-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.report-section {
  background: #f9f9f9;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.report-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.report-content {
  display: block;
  font-size: 26rpx;
  color: var(--color-text);
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.report-chart {
  width: 100%;
  height: 240rpx;
}

.alert-section {
  border-left: 6rpx solid var(--color-warning);
  background: #fff8f0;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-top: 16rpx;
}

.stats-item {
  background: #f9f9f9;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.stats-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stats-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.text-danger { color: var(--color-danger); }
.text-warning { color: var(--color-warning); }
.text-success { color: var(--color-success); }

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.danger {
  color: var(--color-danger);
}

.arrow {
  font-size: 32rpx;
  color: #ddd;
}
