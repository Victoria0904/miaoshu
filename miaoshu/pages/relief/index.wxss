@import "../../styles/variables.wxss";

.header {
  padding: 32rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.summary-card {
  background: var(--color-primary-light);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.summary-row:first-child {
  padding-top: 0;
}

.summary-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.summary-value {
  font-size: 28rpx;
  font-weight: 600;
}

.intensity-low { color: var(--color-success); }
.intensity-mid { color: var(--color-warning); }
.intensity-high { color: var(--color-danger); }

.scene-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-top: 16rpx;
}

.scene-item {
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
  transition: all 0.2s;
}

.scene-active {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
}

.scene-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.scene-label {
  font-size: 28rpx;
  font-weight: 500;
}

.btn-disabled {
  opacity: 0.5;
}

.generating-card {
  text-align: center;
  padding: 80rpx 40rpx;
}

.robot-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.generating-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.generating-sub {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 32rpx;
}

.loading-dots {
  font-size: 48rpx;
  color: var(--color-primary);
  letter-spacing: 8rpx;
  animation: blink 1.2s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.result-summary-card {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #fff;
  text-align: center;
  padding: 40rpx;
}

.result-label {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
}

.result-time-wrap {
  margin-top: 8rpx;
}

.result-time {
  font-size: 80rpx;
  font-weight: 700;
}

.result-unit {
  font-size: 28rpx;
  margin-left: 8rpx;
}

.result-summary {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.action-item {
  background: #f9f9f9;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.action-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.action-index {
  font-size: 24rpx;
  color: #ccc;
  margin-right: 12rpx;
}

.action-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
}

.action-duration {
  font-size: 22rpx;
  color: var(--color-primary);
  background: var(--color-primary-light);
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  margin-top: 8rpx;
}

.action-area {
  display: block;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.avoid-item {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  padding: 8rpx 0;
}

.notice-card {
  background: #fffbed;
}

.notice-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.save-wrap {
  margin: 32rpx;
}
